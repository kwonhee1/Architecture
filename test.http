###############################################################################
# CLI 테스트 시나리오 (.http)
#
# - 모든 아키텍처 구현이 공통으로 통과해야 하는 시나리오.
# - API 계약: shopping-api.yaml / 기능 규칙: 기능명세서 (각 조건을 전수 검증)
#
# 실행 규칙
#  - 각 시나리오(### ==== S## ====)는 자기완결이다: 필요한 user/상품/옵션/포인트를
#    시나리오 안에서 직접 생성한다. 앞 시나리오 상태에 의존하지 않는다.
#  - 로그인(POST /users/login) 성공 시 UserId 쿠키가 발급된다. 쿠키는 저장했다가
#    이후 인증 요청에 사용한다. 한 시나리오 안에서 액터(구매자/판매자/제3자)가
#    바뀌면 그 액터로 재로그인한 뒤 요청한다.
#  - `# @name x` 로 이름 붙인 응답의 값은 {{x}} 로 다음 요청에 쓴다.
#    (id 등 생성 값은 응답 body에서 받아 넘긴다)
#  - `# 기대:` 주석이 각 요청의 성공 판정 기준이다.
#
# 주의
#  - 각 test 케이스의 email은 서로 겹치지 않지만, 같은 DB에 재실행하면 이전 실행의
#    user와 겹쳐 409가 난다. 재실행 시에는 DB를 초기화한다.
#  - db/env를 직접 읽지 말고 api 응답만으로 검증한다.
###############################################################################

@host = http://localhost:8080

###############################################################################
# USER
###############################################################################

### ==== S01 회원가입 정상 + 회원가입 쿠폰 자동 발급 (user-01, coupon-01) ====
# @name s01_signup
# @no-cookie-jar
POST {{host}}/users/register
Content-Type: application/json

{ "email": "s01@test.com", "password": "pw", "name": "S01유저" }

# 기대: 201 (본문 없음)

###
# @name s01_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s01@test.com", "password": "pw" }

# 기대: 200 + Set-Cookie: UserId=...

###
GET {{host}}/coupons

# 기대: 200, 배열에 { name: "회원 가입 쿠폰", discountAmount: 1000 } 1개 (자동 발급 확인)


### ==== S02 회원가입 email 중복 → 409 (user-01: email 중복 확인) ====
# @name s02_first
POST {{host}}/users/register
Content-Type: application/json

{ "email": "s02@test.com", "password": "pw", "name": "S02" }
# 기대: 201

###
POST {{host}}/users/register
Content-Type: application/json

{ "email": "s02@test.com", "password": "pw2", "name": "S02중복" }
# 기대: 409 (이미 존재하는 email)


### ==== S03 회원가입 필수값 누락 → 400 ====
POST {{host}}/users/register
Content-Type: application/json

{ "email": "s03@test.com", "password": "pw" }
# 기대: 400 (name 누락)


### ==== S04 로그인 password 불일치 → 401 (user-02) ====
# @name s04_signup
POST {{host}}/users/register
Content-Type: application/json

{ "email": "s04@test.com", "password": "pw", "name": "S04" }
# 기대: 201

###
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s04@test.com", "password": "wrong" }
# 기대: 401


### ==== S05 로그인 없는 email → 401 ====
POST {{host}}/users/login
Content-Type: application/json

{ "email": "no-such-user@test.com", "password": "pw" }
# 기대: 401


### ==== S06 회원 정보 조회 정상 (user-03: password 미반환) ====
# @name s06_signup
POST {{host}}/users/register
Content-Type: application/json

{ "email": "s06@test.com", "password": "pw", "name": "S06유저" }
# 기대: 201

###
# @name s06_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s06@test.com", "password": "pw" }
# 기대: 200 + 쿠키

###
GET {{host}}/users/me
# 기대: 200, { name: "S06유저", point: 0 }. password 필드 없음


### ==== S07 회원 정보 조회 미인증 → 401 ====
GET {{host}}/users/me
Cookie:
# 기대: 401 (UserId 쿠키 없음)


### ==== S08 포인트 충전 정상 (user-04) ====
# @name s08_signup
POST {{host}}/users/register
Content-Type: application/json

{ "email": "s08@test.com", "password": "pw", "name": "S08" }
###
# @name s08_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s08@test.com", "password": "pw" }
###
POST {{host}}/users/me/points
Content-Type: application/json

{ "point": 10000 }
# 기대: 200, { name: "S08", point: 10000 }


### ==== S09 포인트 충전 <= 0 → 400 (충전 포인트 > 0) ====
# @name s09_login
# (S08 계정 재사용: 재로그인)
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s08@test.com", "password": "pw" }
###
POST {{host}}/users/me/points
Content-Type: application/json

{ "point": 0 }
# 기대: 400
###
POST {{host}}/users/me/points
Content-Type: application/json

{ "point": -100 }
# 기대: 400


### ==== S10 포인트 충전 미인증 → 401 ====
POST {{host}}/users/me/points
Content-Type: application/json
Cookie:

{ "point": 1000 }
# 기대: 401


###############################################################################
# COUPON
###############################################################################

### ==== S11 쿠폰 리스트 미인증 → 401 (coupon-02) ====
GET {{host}}/coupons
Cookie:
# 기대: 401
# (정상 조회/사용 후 소진/취소 후 복원은 ORDER 시나리오에서 검증)


###############################################################################
# PRODUCT
###############################################################################

### ==== S12 상품 등록 정상 + 기본 옵션 자동 생성 (product-01) ====
# @name s12_signup
POST {{host}}/users/register
Content-Type: application/json

{ "email": "s12@test.com", "password": "pw", "name": "S12판매자" }
###
# @name s12_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s12@test.com", "password": "pw" }
###
# 기대: 201, { id, description:"러닝화", price:50000, creator:{ name:"S12판매자" } }
# @name s12_product
POST {{host}}/products
Content-Type: application/json

{ "description": "러닝화", "price": 50000 }

> {%
    client.log("s12_product = " + response.body.id);
    client.global.set("s12_product", response.body.id);
%}
###
GET {{host}}/products/{{s12_product}}
# 기대: 200, options 배열에 기본 옵션 { description:"기본 옵션", additionalPrice:0, stock:0 } 포함


### ==== S13 상품 등록 price <= 0 → 400 (판매 금액 > 0) ====
# @name s13_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s12@test.com", "password": "pw" }
###
POST {{host}}/products
Content-Type: application/json

{ "description": "무료상품", "price": 0 }
# 기대: 400


### ==== S14 상품 등록 미인증 → 401 ====
POST {{host}}/products
Content-Type: application/json
Cookie:

{ "description": "x", "price": 1000 }
# 기대: 401


### ==== S15 상품 수정 정상 - 설명/금액 (order 없음) (product-02) ====
# @name s15_signup
POST {{host}}/users/register
Content-Type: application/json

{ "email": "s15@test.com", "password": "pw", "name": "S15판매자" }
###
# @name s15_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s15@test.com", "password": "pw" }
###
# @name s15_product
POST {{host}}/products
Content-Type: application/json

{ "description": "구버전", "price": 10000 }

> {%
    client.log("s15_product = " + response.body.id);
    client.global.set("s15_product", response.body.id);
%}
###
# 수정할 값만 전송 (null 허용): 설명만
PATCH {{host}}/products/{{s15_product}}
Content-Type: application/json

{ "description": "신버전" }
# 기대: 200, description "신버전", price 10000 유지
###
# order 없으므로 금액 수정 가능
PATCH {{host}}/products/{{s15_product}}
Content-Type: application/json

{ "price": 20000 }
# 기대: 200, price 20000


### ==== S16 상품 수정 price <= 0 → 400 ====
# @name s16_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s15@test.com", "password": "pw" }
###
PATCH {{host}}/products/{{s15_product}}
Content-Type: application/json

{ "price": 0 }
# 기대: 400


### ==== S17 상품 수정 - 생성자 아님 → 403 ====
# 제3자 생성
# @name s17_signup
POST {{host}}/users/register
Content-Type: application/json

{ "email": "s17other@test.com", "password": "pw", "name": "제3자" }
###
# @name s17_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s17other@test.com", "password": "pw" }
###
PATCH {{host}}/products/{{s15_product}}
Content-Type: application/json

{ "description": "남의상품수정시도" }
# 기대: 403


### ==== S18 상품 수정 미인증 → 401 ====
PATCH {{host}}/products/{{s15_product}}
Content-Type: application/json
Cookie:

{ "description": "x" }
# 기대: 401


### ==== S19 상품 리스트 조회 (공개) (product-03) ====
GET {{host}}/products
# 기대: 200, 판매중 상품 배열 (옵션 정보 미포함). 인증 불필요


### ==== S20 상품 상세 조회 + 없는 상품 404 (product-04) ====
GET {{host}}/products/{{s12_product}}
# 기대: 200, 옵션 리스트 포함. 인증 불필요
###
GET {{host}}/products/99999999
# 기대: 404


### ==== S21 내 상품 리스트 조회 - 타인 상품 제외 (product-05) ====
# 판매자 A
# @name s21a_signup
POST {{host}}/users/register
Content-Type: application/json

{ "email": "s21a@test.com", "password": "pw", "name": "S21A" }
###
# @name s21a_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s21a@test.com", "password": "pw" }
###
# @name s21a_product
POST {{host}}/products
Content-Type: application/json

{ "description": "A의상품", "price": 1000 }
###
# 판매자 B
# @name s21b_signup
POST {{host}}/users/register
Content-Type: application/json

{ "email": "s21b@test.com", "password": "pw", "name": "S21B" }
###
# @name s21b_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s21b@test.com", "password": "pw" }
###
# B가 조회 → B 상품만, A의상품 미포함
GET {{host}}/products/me
# 기대: 200, "A의상품" 미포함 (본인 것만)


### ==== S22 내 상품 리스트 미인증 → 401 ====
GET {{host}}/products/me
Cookie:
# 기대: 401


###############################################################################
# OPTION
###############################################################################

### ==== S23 옵션 생성 정상 (option-01) ====
# @name s23_signup
POST {{host}}/users/register
Content-Type: application/json

{ "email": "s23@test.com", "password": "pw", "name": "S23판매자" }
###
# @name s23_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s23@test.com", "password": "pw" }
###
# @name s23_product
POST {{host}}/products
Content-Type: application/json

{ "description": "옵션테스트상품", "price": 50000 }

> {%
    client.log("s23_product = " + response.body.id);
    client.global.set("s23_product", response.body.id);
%}
###
# 기대: 201, { id, description:"270", additionalPrice:5000, stock:100 }
# @name s23_option
POST {{host}}/options/{{s23_product}}
Content-Type: application/json

{ "description": "270", "additionalPrice": 5000, "stock": 100 }

> {%
    client.log("s23_option = " + response.body.id);
    client.global.set("s23_option", response.body.id);
%}


### ==== S24 옵션 생성 (추가금액 + 상품금액) <= 0 → 400 ====
# 상품금액 50000, 추가금액 -50000 → 합 0
# @name s24_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s23@test.com", "password": "pw" }
###
POST {{host}}/options/{{s23_product}}
Content-Type: application/json

{ "description": "합0옵션", "additionalPrice": -50000, "stock": 10 }
# 기대: 400


### ==== S25 옵션 생성 재고 < 0 → 400 (재고 >= 0) ====
POST {{host}}/options/{{s23_product}}
Content-Type: application/json

{ "description": "음수재고", "additionalPrice": 1000, "stock": -1 }
# 기대: 400


### ==== S26 옵션 생성 - 생성자 아님 → 403 ====
# @name s26_signup
POST {{host}}/users/register
Content-Type: application/json

{ "email": "s26other@test.com", "password": "pw", "name": "제3자" }
###
# @name s26_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s26other@test.com", "password": "pw" }
###
POST {{host}}/options/{{s23_product}}
Content-Type: application/json

{ "description": "무단옵션", "additionalPrice": 1000, "stock": 1 }
# 기대: 403


### ==== S27 옵션 생성 미인증 → 401 ====
POST {{host}}/options/{{s23_product}}
Content-Type: application/json
Cookie:

{ "description": "x", "additionalPrice": 1000, "stock": 1 }
# 기대: 401


### ==== S28 옵션 수정 정상 (order 없음) (option-02) ====
# @name s28_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s23@test.com", "password": "pw" }
###
PATCH {{host}}/options/{{s23_option}}
Content-Type: application/json

{ "description": "270(리뉴얼)", "additionalPrice": 6000, "stock": 80 }
# 기대: 200, 값 반영


### ==== S29 옵션 수정 (추가금액 + 상품금액) <= 0 → 400 ====
PATCH {{host}}/options/{{s23_option}}
Content-Type: application/json

{ "additionalPrice": -50000 }
# 기대: 400 (상품금액 50000 + (-50000) = 0)


### ==== S30 옵션 수정 재고 < 0 → 400 ====
PATCH {{host}}/options/{{s23_option}}
Content-Type: application/json

{ "stock": -5 }
# 기대: 400


### ==== S31 옵션 수정 - 생성자 아님 → 403 ====
# @name s31_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s26other@test.com", "password": "pw" }
###
PATCH {{host}}/options/{{s23_option}}
Content-Type: application/json

{ "description": "무단수정" }
# 기대: 403


### ==== S32 옵션 삭제 정상 (order 없음) → 204 ====
# 삭제 전용 옵션을 새로 만들어 삭제
# @name s32_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s23@test.com", "password": "pw" }
###
# @name s32_option
POST {{host}}/options/{{s23_product}}
Content-Type: application/json

{ "description": "삭제될옵션", "additionalPrice": 1000, "stock": 5 }

> {%
    client.log("s32_option = " + response.body.id);
    client.global.set("s32_option", response.body.id);
%}
###
DELETE {{host}}/options/{{s32_option}}
# 기대: 204


###############################################################################
# ORDER (핵심)
###############################################################################

### ==== S33 주문 정상 - 쿠폰 없이 (order-01) ====
# 구매자
# @name s33_buyer_signup
POST {{host}}/users/register
Content-Type: application/json

{ "email": "s33buyer@test.com", "password": "pw", "name": "S33구매자" }
###
# @name s33_buyer_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s33buyer@test.com", "password": "pw" }
###
POST {{host}}/users/me/points
Content-Type: application/json

{ "point": 200000 }
# 기대: 200, point 200000
###
# 판매자 + 상품/옵션 (재고 10)
# @name s33_seller_signup
POST {{host}}/users/register
Content-Type: application/json

{ "email": "s33seller@test.com", "password": "pw", "name": "S33판매자" }
###
# @name s33_seller_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s33seller@test.com", "password": "pw" }
###
# @name s33_product
POST {{host}}/products
Content-Type: application/json

{ "description": "S33상품", "price": 50000 }

> {%
    client.log("s33_product = " + response.body.id);
    client.global.set("s33_product", response.body.id);
%}
###
# @name s33_option
POST {{host}}/options/{{s33_product}}
Content-Type: application/json

{ "description": "opt", "additionalPrice": 5000, "stock": 10 }

> {%
    client.log("s33_option = " + response.body.id);
    client.global.set("s33_option", response.body.id);
%}
###
# 구매자로 재로그인 후 주문 (쿠폰 미사용). 단가 55000 * 1 = 55000
# @name s33_buyer_relogin
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s33buyer@test.com", "password": "pw" }
###
# @name s33_order
POST {{host}}/orders
Content-Type: application/json

{ "orderItems": [ { "optionId": {{s33_option}}, "count": 1 } ] }
# 기대: 201, amount 55000, orderDate(date), orderer.name "S33구매자"
###
# 포인트 차감 확인
GET {{host}}/users/me
# 기대: point 200000 - 55000 = 145000
###
# 재고 차감 확인
GET {{host}}/products/{{s33_product}}
# 기대: 해당 옵션 stock 10 - 1 = 9


### ==== S34 주문 정상 - 쿠폰 사용 + 쿠폰 소진 확인 (order-01) ====
# @name s34_buyer_signup
POST {{host}}/users/register
Content-Type: application/json

{ "email": "s34buyer@test.com", "password": "pw", "name": "S34구매자" }
###
# @name s34_buyer_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s34buyer@test.com", "password": "pw" }
###
POST {{host}}/users/me/points
Content-Type: application/json

{ "point": 200000 }
###
# 가입 쿠폰(1000) id 확보
# 기대: 200, 회원 가입 쿠폰 1개
# @name s34_coupons
GET {{host}}/coupons

> {%
    client.log("s34_coupons = " + response.body[0].id);
    client.global.set("s34_coupons", response.body[0].id);
%}
###
# 판매자/상품/옵션
# @name s34_seller_signup
POST {{host}}/users/register
Content-Type: application/json

{ "email": "s34seller@test.com", "password": "pw", "name": "S34판매자" }
###
# @name s34_seller_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s34seller@test.com", "password": "pw" }
###
# @name s34_product
POST {{host}}/products
Content-Type: application/json

{ "description": "S34상품", "price": 50000 }

> {%
    client.log("s34_product = " + response.body.id);
    client.global.set("s34_product", response.body.id);
%}
###
# @name s34_option
POST {{host}}/options/{{s34_product}}
Content-Type: application/json

{ "description": "opt", "additionalPrice": 5000, "stock": 10 }

> {%
    client.log("s34_option = " + response.body.id);
    client.global.set("s34_option", response.body.id);
%}
###
# 구매자 재로그인 후 쿠폰 사용 주문. 55000 - 1000 = 54000
# @name s34_buyer_relogin
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s34buyer@test.com", "password": "pw" }
###
POST {{host}}/orders
