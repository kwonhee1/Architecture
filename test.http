###
# 판매자/상품/옵션 (재고 10)
# @name s51_seller_signup
POST {{host}}/users/register
Content-Type: application/json

{ "email": "s51seller@test.com", "password": "pw", "name": "S51판매자" }
###
# @name s51_seller_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s51seller@test.com", "password": "pw" }
###
# @name s51_product
POST {{host}}/products
Content-Type: application/json

{ "description": "S51상품", "price": 50000 }

> {%
    client.log("s51_product = " + response.body.id);
    client.global.set("s51_product", response.body.id);
%}
###
# @name s51_option
POST {{host}}/options/{{s51_product}}
Content-Type: application/json

{ "description": "opt", "additionalPrice": 5000, "stock": 10 }

> {%
    client.log("s51_option = " + response.body.id);
    client.global.set("s51_option", response.body.id);
%}
###
# 구매자 재로그인 후 쿠폰 사용 주문. 55000 - 1000 = 54000
# @name s51_buyer_relogin
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s51buyer@test.com", "password": "pw" }
###
# 기대: 201, amount = 55000*2 - 1000 = 109000. point 200000-109000=91000
# @name s51_order
POST {{host}}/orders
Content-Type: application/json

{ "orderItems": [ { "optionId": {{s51_option}}, "count": 2 } ], "couponId": {{s51_coupons}} }

> {%
    client.log("s51_order = " + response.body.id);
    client.global.set("s51_order", response.body.id);
%}
###
# 주문 취소
DELETE {{host}}/orders/{{s51_order}}
# 기대: 204 (본문 없음). 포인트/재고/쿠폰 복원은 아래 후속 조회로 확인
###
# 포인트 복원 확인
GET {{host}}/users/me
# 기대: point 200000 (차감분 전액 복원)
###
# 쿠폰 복원 확인 (사용 가능 상태로 복원)
GET {{host}}/coupons
# 기대: 가입 쿠폰 다시 조회됨 (1개)
###
# 재고 복원 확인
GET {{host}}/products/{{s51_product}}
# 기대: 옵션 stock 10 (복원)


### ==== S52 주문 취소 - 내 주문 아님 → 403 ====
# 자기완결: 구매자 주문을 새로 만든 뒤, 제3자가 취소 시도
# @name s52_buyer_signup
POST {{host}}/users/register
Content-Type: application/json

{ "email": "s52buyer@test.com", "password": "pw", "name": "S52구매자" }
###
# @name s52_buyer_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s52buyer@test.com", "password": "pw" }
###
POST {{host}}/users/me/points
Content-Type: application/json

{ "point": 200000 }
###
# @name s52_seller_signup
POST {{host}}/users/register
Content-Type: application/json

{ "email": "s52seller@test.com", "password": "pw", "name": "S52판매자" }
###
# @name s52_seller_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s52seller@test.com", "password": "pw" }
###
# @name s52_product
POST {{host}}/products
Content-Type: application/json

{ "description": "S52상품", "price": 50000 }

> {%
    client.log("s52_product = " + response.body.id);
    client.global.set("s52_product", response.body.id);
%}
###
# @name s52_option
POST {{host}}/options/{{s52_product}}
Content-Type: application/json

{ "description": "opt", "additionalPrice": 5000, "stock": 10 }

> {%
    client.log("s52_option = " + response.body.id);
    client.global.set("s52_option", response.body.id);
%}
###
# @name s52_buyer_relogin
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s52buyer@test.com", "password": "pw" }
###
# 기대: 201
# @name s52_order
POST {{host}}/orders
Content-Type: application/json

{ "orderItems": [ { "optionId": {{s52_option}}, "count": 1 } ] }

> {%
    client.log("s52_order = " + response.body.id);
    client.global.set("s52_order", response.body.id);
%}
###
# 제3자 로그인 후 취소 시도
# @name s52_other_signup
POST {{host}}/users/register
Content-Type: application/json

{ "email": "s52other@test.com", "password": "pw", "name": "제3자" }
###
# @name s52_other_login
POST {{host}}/users/login
Content-Type: application/json

{ "email": "s52other@test.com", "password": "pw" }
###
DELETE {{host}}/orders/{{s52_order}}
# 기대: 403 (내 주문만 취소 가능). 주문은 삭제되지 않음


